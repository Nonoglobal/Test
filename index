<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GEOINT / Field Editor</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Barlow+Condensed:wght@300;400;600;700;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<style>
:root{
  --black:#000;--gray900:#0a0a0a;--gray800:#111;--gray700:#1a1a1a;
  --gray600:#262626;--gray500:#333;--gray400:#555;--gray300:#888;
  --gray200:#bbb;--gray100:#e0e0e0;--white:#fff;--red:#ff2222;--ai:#39ff14;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{width:100%;height:100%;overflow:hidden;background:var(--black);color:var(--white)}
body{font-family:'Barlow Condensed',sans-serif;display:flex;flex-direction:column}

/* ── Z-FIX ── */
#topbar,#sidebar,#statusbar{position:relative;z-index:10000!important}
.leaflet-top,.leaflet-bottom{z-index:900!important}

/* ── TOPBAR ── */
#topbar{
  height:44px;background:var(--black);border-bottom:1px solid var(--gray600);
  display:flex;align-items:center;padding:0 16px;gap:0;flex-shrink:0;
}
.tb-logo{font-family:'Share Tech Mono',monospace;font-size:13px;letter-spacing:3px;
  color:var(--white);padding-right:20px;margin-right:20px;border-right:1px solid var(--gray600);white-space:nowrap}
.tb-logo span{color:var(--gray300)}
.tb-sep{width:1px;height:24px;background:var(--gray600);margin:0 12px}
.tb-btn{font-family:'Share Tech Mono',monospace;font-size:11px;letter-spacing:1px;
  padding:6px 14px;background:transparent;border:1px solid transparent;
  color:var(--gray300);cursor:pointer;transition:all .12s;text-transform:uppercase;white-space:nowrap}
.tb-btn:hover{color:var(--white);border-color:var(--gray500)}
.tb-btn.danger{color:var(--gray400)}.tb-btn.danger:hover{color:var(--red);border-color:var(--red)}
.tb-right{margin-left:auto;display:flex;align-items:center;gap:0}
#sysinfo{font-family:'Share Tech Mono',monospace;font-size:10px;color:var(--gray400);letter-spacing:1px;
  margin-left:20px;padding-left:20px;border-left:1px solid var(--gray600)}

/* ── MAIN ── */
#main{display:flex;flex:1;overflow:hidden}
#map{flex:1;position:relative}
#map.mode-view{cursor:default}
#map.mode-draw{cursor:crosshair}
#map.mode-tag{cursor:cell}
#map.mode-free{cursor:crosshair}
#map.mode-zone{cursor:crosshair}

.leaflet-container{background:#000}
.leaflet-control-zoom a{background:var(--gray800)!important;color:var(--white)!important;
  border-color:var(--gray600)!important;font-family:'Share Tech Mono',monospace!important}
.leaflet-control-zoom a:hover{background:var(--gray600)!important}
.leaflet-control-attribution{background:rgba(0,0,0,.6)!important;color:var(--gray400)!important;font-size:9px!important}

/* ── FREEHAND CANVAS overlay ── */
#freeCanvas{
  position:absolute;top:0;left:0;width:100%;height:100%;
  pointer-events:none;z-index:500;display:none;
}
#freeCanvas.active{pointer-events:all;display:block}

/* ── SIDEBAR ── */
#sidebar{width:280px;flex-shrink:0;background:var(--black);border-left:1px solid var(--gray600);
  display:flex;flex-direction:column;overflow:hidden}
.sb-header{padding:10px 14px;border-bottom:1px solid var(--gray600);
  display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.sb-header-title{font-family:'Share Tech Mono',monospace;font-size:10px;letter-spacing:2px;
  color:var(--gray300);text-transform:uppercase}
.sb-count{font-family:'Share Tech Mono',monospace;font-size:10px;color:var(--white);
  background:var(--gray700);border:1px solid var(--gray500);padding:1px 8px;border-radius:2px}

/* ── TOOLS ── */
#toolpanel{border-bottom:1px solid var(--gray600);padding:10px;flex-shrink:0;display:flex;flex-direction:column;gap:8px}
.tool-section-label{font-family:'Share Tech Mono',monospace;font-size:9px;letter-spacing:2px;
  color:var(--gray400);text-transform:uppercase;margin-bottom:2px}
.tool-row{display:flex;gap:5px;flex-wrap:wrap}
.tool-btn{font-family:'Share Tech Mono',monospace;font-size:10px;letter-spacing:.5px;
  padding:7px 6px;background:var(--gray800);border:1px solid var(--gray600);
  color:var(--gray200);cursor:pointer;transition:all .1s;display:flex;align-items:center;
  gap:4px;text-transform:uppercase;flex:1;justify-content:center;white-space:nowrap}
.tool-btn:hover{border-color:var(--gray300);color:var(--white);background:var(--gray700)}
.tool-btn.active{background:var(--white);color:var(--black);border-color:var(--white)}
.tool-btn.ai-btn{border-color:#1a3a1a}
.tool-btn.ai-btn:hover{border-color:var(--ai);color:var(--ai);background:#0a1a0a}
.tool-btn.ai-btn.active{background:var(--ai);color:var(--black);border-color:var(--ai)}

.ai-hint{font-family:'Share Tech Mono',monospace;font-size:9px;color:#2a5a2a;
  letter-spacing:.5px;padding:4px 2px;line-height:1.6;display:none}
.ai-hint.visible{display:block;color:#39aa14}

.cat-grid{display:grid;grid-template-columns:1fr 1fr;gap:5px}
.cat-btn{font-family:'Share Tech Mono',monospace;font-size:9px;letter-spacing:.5px;
  padding:6px 8px;background:var(--gray900);border:1px solid var(--gray600);
  color:var(--gray300);cursor:pointer;transition:all .1s;display:flex;align-items:center;gap:5px;text-transform:uppercase}
.cat-btn:hover{border-color:var(--white);color:var(--white)}
.cat-btn.selected{border-color:var(--white);background:var(--gray700);color:var(--white)}
.cat-btn .cat-icon{font-size:12px;flex-shrink:0}

/* ── OBJECT LIST ── */
#objList{flex:1;overflow-y:auto;padding:4px}
#objList::-webkit-scrollbar{width:3px}
#objList::-webkit-scrollbar-thumb{background:var(--gray600)}
.obj-card{display:flex;align-items:center;gap:8px;padding:7px 8px;
  border:1px solid transparent;border-bottom-color:var(--gray800);cursor:pointer;transition:all .1s}
.obj-card:hover{background:var(--gray800);border-color:var(--gray600)}
.obj-card.sel{background:var(--gray800);border-color:var(--gray500)}
.obj-icon{font-size:14px;flex-shrink:0;width:20px;text-align:center}
.obj-info{flex:1;min-width:0}
.obj-name{font-size:12px;font-weight:700;letter-spacing:.5px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.obj-meta{font-family:'Share Tech Mono',monospace;font-size:9px;color:var(--gray400);margin-top:1px;letter-spacing:.5px}
.obj-actions{display:flex;gap:4px;opacity:0;transition:opacity .1s}
.obj-card:hover .obj-actions{opacity:1}
.obj-action-btn{width:22px;height:22px;border-radius:2px;background:transparent;
  border:1px solid var(--gray600);color:var(--gray300);cursor:pointer;font-size:11px;
  display:flex;align-items:center;justify-content:center;transition:all .1s}
.obj-action-btn:hover{border-color:var(--red);color:var(--red);background:rgba(255,34,34,.08)}
.obj-action-btn.edit:hover{border-color:var(--gray200);color:var(--white)}
.empty-state{padding:40px 20px;text-align:center;font-family:'Share Tech Mono',monospace;
  font-size:10px;color:var(--gray500);letter-spacing:1px;line-height:2}

/* ── STATUSBAR ── */
#statusbar{height:26px;background:var(--black);border-top:1px solid var(--gray700);
  display:flex;align-items:center;padding:0 14px;gap:0;
  font-family:'Share Tech Mono',monospace;font-size:10px;color:var(--gray400);letter-spacing:.5px;flex-shrink:0}
.sb-seg{padding:0 12px;border-right:1px solid var(--gray700)}
.sb-seg:first-child{padding-left:0}
.sb-live{color:var(--white)}
.sb-dot{width:5px;height:5px;border-radius:50%;background:#33ff88;display:inline-block;margin-right:5px;animation:pulse-dot 2s infinite}
@keyframes pulse-dot{0%,100%{opacity:1}50%{opacity:.3}}

/* ── MODAL ── */
#modalBg{position:fixed;inset:0;background:rgba(0,0,0,.85);display:flex;align-items:center;
  justify-content:center;z-index:9000;opacity:0;pointer-events:none;transition:opacity .15s;backdrop-filter:blur(2px)}
#modalBg.open{opacity:1;pointer-events:all}
#modal{background:var(--gray900);border:1px solid var(--gray500);width:400px;max-width:95vw;
  transform:translateY(8px);transition:transform .15s}
#modalBg.open #modal{transform:translateY(0)}
.modal-head{padding:14px 18px;border-bottom:1px solid var(--gray700);display:flex;align-items:center;
  gap:10px;background:var(--black)}
.modal-head-title{font-family:'Share Tech Mono',monospace;font-size:11px;letter-spacing:2px;color:var(--gray200);text-transform:uppercase}
.modal-head-cat{margin-left:auto;font-size:9px;font-family:'Share Tech Mono',monospace;color:var(--gray400);letter-spacing:1px}
.modal-body{padding:18px}
.field{margin-bottom:14px}
.field label{display:block;font-family:'Share Tech Mono',monospace;font-size:9px;letter-spacing:2px;
  text-transform:uppercase;color:var(--gray400);margin-bottom:5px}
.field input,.field textarea{width:100%;background:var(--black);border:1px solid var(--gray600);
  color:var(--white);padding:8px 10px;font-family:'Share Tech Mono',monospace;font-size:12px;
  outline:none;transition:border-color .1s}
.field input:focus,.field textarea:focus{border-color:var(--white)}
.field textarea{resize:vertical;min-height:60px}
.rotate-field{display:flex;align-items:center;gap:10px}
.rotate-field input[type=range]{flex:1;accent-color:var(--white)}
.rotate-val{font-family:'Share Tech Mono',monospace;font-size:11px;color:var(--white);min-width:40px;text-align:right}
.modal-foot{padding:12px 18px;border-top:1px solid var(--gray700);
  display:flex;justify-content:flex-end;gap:8px;background:var(--black)}
.mbtn{font-family:'Share Tech Mono',monospace;font-size:10px;letter-spacing:1px;text-transform:uppercase;
  padding:7px 18px;cursor:pointer;border:1px solid var(--gray500);background:transparent;color:var(--gray200);transition:all .1s}
.mbtn:hover{border-color:var(--gray200);color:var(--white)}
.mbtn.primary{background:var(--white);color:var(--black);border-color:var(--white)}
.mbtn.primary:hover{background:var(--gray200)}

/* ── AI PROCESSING OVERLAY ── */
#aiOverlay{
  position:fixed;inset:0;background:rgba(0,0,0,.92);
  display:none;align-items:center;justify-content:center;
  z-index:9500;flex-direction:column;gap:20px;
  font-family:'Share Tech Mono',monospace;
}
#aiOverlay.open{display:flex}
.ai-spinner{
  width:48px;height:48px;
  border:1px solid #1a3a1a;
  border-top-color:var(--ai);
  border-radius:50%;
  animation:spin 1s linear infinite;
}
@keyframes spin{to{transform:rotate(360deg)}}
.ai-status{color:var(--ai);font-size:11px;letter-spacing:2px;text-transform:uppercase}
.ai-sub{color:var(--gray500);font-size:9px;letter-spacing:1px;margin-top:-12px}



@keyframes dash-fast{to{stroke-dashoffset:-12}}
@keyframes dash-slow{to{stroke-dashoffset:-28}}
@keyframes dash-pulse{0%,100%{stroke-opacity:1;stroke-width:1.5}50%{stroke-opacity:.3;stroke-width:3}}
@keyframes dash-blink{0%,49%{stroke-opacity:1}50%,100%{stroke-opacity:0}}
@keyframes dash-glow{0%,100%{filter:drop-shadow(0 0 1px currentColor)}50%{filter:drop-shadow(0 0 6px currentColor)}}
@keyframes fill-breathe{0%,100%{fill-opacity:.08}50%{fill-opacity:.22}}

.leaflet-interactive.anim-march{stroke-dasharray:8 4;animation:dash-march 1.2s linear infinite}
.leaflet-interactive.anim-fast{stroke-dasharray:5 3;animation:dash-fast .5s linear infinite}
.leaflet-interactive.anim-slow{stroke-dasharray:12 6;animation:dash-slow 2.5s linear infinite}
.leaflet-interactive.anim-pulse{stroke-dasharray:none;animation:dash-pulse 1.5s ease-in-out infinite}
.leaflet-interactive.anim-blink{stroke-dasharray:none;animation:dash-blink 1s step-end infinite}
.leaflet-interactive.anim-glow{stroke-dasharray:none;animation:dash-glow 2s ease-in-out infinite}
.leaflet-interactive.anim-breathe{stroke-dasharray:6 4;animation:dash-march 1.5s linear infinite,fill-breathe 2s ease-in-out infinite}
.leaflet-interactive.anim-none{stroke-dasharray:none;animation:none}

/* ── ANIMATED POLYGON DASHES ── */
@keyframes dash-march{to{stroke-dashoffset:-20}}
@keyframes dash-march-zone{to{stroke-dashoffset:-16}}
@keyframes zone-pulse{0%,100%{fill-opacity:.12}50%{fill-opacity:.22}}

.leaflet-interactive.anim-rect{
  stroke-dasharray:8 4;
  animation:dash-march 1.2s linear infinite;
}
.leaflet-interactive.anim-zone{
  stroke-dasharray:6 4;
  animation:dash-march-zone .8s linear infinite;
}
.leaflet-interactive.anim-free{
  stroke-dasharray:5 3;
  animation:dash-march .9s linear infinite;
}

/* ── ZONE BUTTON ── */
.tool-btn.zone-btn{border-color:#3a0a0a}
.tool-btn.zone-btn:hover{border-color:var(--red);color:var(--red);background:#1a0505}
.tool-btn.zone-btn.active{background:var(--red);color:var(--white);border-color:var(--red)}
.zone-hint{font-family:'Share Tech Mono',monospace;font-size:9px;color:#3a0a0a;
  letter-spacing:.5px;padding:4px 2px;line-height:1.6;display:none}
.zone-hint.visible{display:block;color:#cc2222}

/* ── ANIMATED TAGS ── */
@keyframes ring-pulse{0%{transform:scale(1);opacity:.9}50%{transform:scale(2.2);opacity:0}100%{transform:scale(1);opacity:0}}
@keyframes dot-blink{0%,100%{opacity:1}50%{opacity:.4}}
.tag-marker{position:relative;width:20px;height:20px;display:flex;align-items:center;justify-content:center}
.tag-dot{width:8px;height:8px;border-radius:50%;position:relative;z-index:2}
.tag-ring{position:absolute;width:8px;height:8px;border-radius:50%;border:1px solid currentColor;animation:ring-pulse 2s infinite}
.tag-ring2{position:absolute;width:8px;height:8px;border-radius:50%;border:1px solid currentColor;animation:ring-pulse 2s .6s infinite}
.tag-vehicle .tag-dot{border-radius:0;width:10px;height:10px;background:transparent;border:1.5px solid var(--white);animation:dot-blink 1.5s infinite}
.tag-vehicle::before,.tag-vehicle::after{content:'';position:absolute;background:var(--white)}
.tag-vehicle::before{width:1px;height:18px;top:1px;left:9px}
.tag-vehicle::after{width:18px;height:1px;top:9px;left:1px}
.tag-building .tag-dot{background:var(--white);border-radius:2px}
.tag-building .tag-ring{border-color:var(--white);border-radius:2px;animation:ring-pulse 2.5s infinite}
.tag-road .tag-dot{background:var(--gray200);width:6px;height:10px;border-radius:1px}
.tag-road .tag-ring{border-color:var(--gray200)}
.tag-water .tag-dot{background:var(--white);border-radius:50% 50% 50% 0;transform:rotate(-45deg);width:8px;height:8px}
.tag-water .tag-ring{border-color:var(--white);animation:ring-pulse 3s infinite}
.tag-area .tag-dot{background:transparent;border:1.5px solid var(--gray200);border-radius:0;width:10px;height:10px}
.tag-area .tag-ring{border-color:var(--gray200);border-radius:0;animation:ring-pulse 2s infinite}
.tag-poi .tag-dot{background:var(--white);clip-path:polygon(50% 0%,100% 100%,0% 100%);border-radius:0;width:10px;height:10px}
.tag-poi .tag-ring{border-color:var(--white);animation:ring-pulse 1.8s infinite}
.tag-label{position:absolute;left:14px;top:-4px;background:rgba(0,0,0,.88);border:1px solid var(--gray500);
  padding:2px 6px;font-family:'Share Tech Mono',monospace;font-size:9px;letter-spacing:.5px;white-space:nowrap;color:var(--white);pointer-events:none}
.tag-label::before{content:'';position:absolute;left:-5px;top:50%;transform:translateY(-50%);
  border:4px solid transparent;border-right-color:var(--gray500)}


/* ── COLOR & ANIMATION PICKER ── */
.color-row{display:flex;gap:6px;flex-wrap:wrap;margin-top:4px}
.color-swatch{
  width:22px;height:22px;border-radius:2px;cursor:pointer;
  border:2px solid transparent;transition:all .1s;flex-shrink:0;
  position:relative;
}
.color-swatch:hover{transform:scale(1.15)}
.color-swatch.sel{border-color:#fff;transform:scale(1.15)}
.color-swatch.sel::after{content:'✓';position:absolute;top:50%;left:50%;
  transform:translate(-50%,-50%);font-size:10px;color:#000;font-weight:900;line-height:1}

.anim-grid{display:grid;grid-template-columns:1fr 1fr;gap:5px;margin-top:4px}
.anim-btn{
  font-family:'Share Tech Mono',monospace;font-size:9px;letter-spacing:.5px;
  padding:7px 8px;background:var(--gray900);border:1px solid var(--gray600);
  color:var(--gray300);cursor:pointer;transition:all .1s;text-transform:uppercase;
  display:flex;align-items:center;gap:6px;
}
.anim-btn:hover{border-color:var(--white);color:var(--white)}
.anim-btn.sel{border-color:var(--white);background:var(--gray700);color:var(--white)}
.anim-preview{width:28px;height:8px;border-radius:1px;flex-shrink:0}

/* ── TOAST ── */
#toast{position:fixed;bottom:40px;left:50%;transform:translateX(-50%) translateY(10px);
  background:var(--gray800);border:1px solid var(--gray500);font-family:'Share Tech Mono',monospace;
  font-size:10px;letter-spacing:1px;color:var(--white);padding:8px 18px;
  opacity:0;transition:all .15s;pointer-events:none;z-index:9999;text-transform:uppercase}
#toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

/* ── JSON ── */
#jsonPanel{position:fixed;inset:0;background:rgba(0,0,0,.9);display:none;flex-direction:column;
  align-items:center;justify-content:center;z-index:9500}
#jsonPanel.open{display:flex}
.json-box{background:var(--gray900);border:1px solid var(--gray500);width:640px;max-width:95vw;max-height:80vh;display:flex;flex-direction:column}
.json-box-head{padding:12px 16px;border-bottom:1px solid var(--gray700);background:var(--black);
  font-family:'Share Tech Mono',monospace;font-size:10px;letter-spacing:2px;color:var(--gray300);display:flex;justify-content:space-between;align-items:center}
.json-box pre{flex:1;overflow:auto;padding:14px;font-family:'Share Tech Mono',monospace;font-size:11px;color:var(--gray200);line-height:1.6}

/* ── CONTEXT MENU ── */
#ctxMenu{position:fixed;z-index:8000;display:none;background:var(--gray900);border:1px solid var(--gray500);min-width:160px}
.ctx-item{padding:8px 14px;font-family:'Share Tech Mono',monospace;font-size:10px;letter-spacing:.5px;
  text-transform:uppercase;color:var(--gray200);cursor:pointer;transition:all .1s}
.ctx-item:hover{background:var(--gray700);color:var(--white)}
.ctx-item.danger{color:var(--gray400)}.ctx-item.danger:hover{color:var(--red);background:rgba(255,34,34,.06)}
.ctx-sep{height:1px;background:var(--gray700);margin:2px 0}
</style>
</head>
<body>

<!-- TOPBAR -->
<div id="topbar">
  <div class="tb-logo">GEOINT <span>// FIELD EDITOR</span></div>
  <button class="tb-btn" onclick="exportJSON()">↓ EXPORT</button>
  <button class="tb-btn" onclick="doImport()">↑ IMPORT</button>
  <div class="tb-sep"></div>
  <button class="tb-btn danger" onclick="clearAll()">✕ CLEAR ALL</button>
  <div class="tb-sep"></div>
  <button class="tb-btn" id="aisToggleBtn" onclick="toggleAIS()" style="border-color:#1a3a1a;color:#2a6a2a">⚓ AIS LIVE</button>
  <div id="sysinfo">SYSTEM NOMINAL · <span id="objCountTop">0</span> OBJ · <span id="aisCount" style="color:#39ff14">AIS: —</span></div>
</div>

<!-- MAIN -->
<div id="main">
  <div id="map" style="position:relative">
    <!-- Freehand draw canvas sits over the map -->
    <canvas id="freeCanvas"></canvas>
  </div>

  <div id="sidebar">
    <div class="sb-header">
      <span class="sb-header-title">Object Registry</span>
      <span class="sb-count" id="sbCount">0</span>
    </div>

    <div id="toolpanel">
      <div class="tool-section-label">Draw Mode</div>
      <div class="tool-row">
        <button class="tool-btn active" id="btnView" onclick="setMode('view')">🖐 VIEW</button>
        <button class="tool-btn" id="btnDraw" onclick="setMode('draw')">▭ POLY</button>
        <button class="tool-btn" id="btnTag"  onclick="setMode('tag')">◉ TAG</button>
        <button class="tool-btn ai-btn" id="btnFree" onclick="setMode('free')" title="Freihand zeichnen – OBB Rechteck">✦ FREI</button>
        <button class="tool-btn zone-btn" id="btnZone" onclick="setMode('zone')" title="Sperrgebiet freihand zeichnen">⛔ ZONE</button>
      </div>
      <div class="ai-hint" id="aiHint">
        FREIHAND ZEICHNEN — FORM WIRD
AUTOMATISCH ALS RECHTECK ERKANNT.
      </div>
      <div class="zone-hint" id="zoneHint">FREIHAND SPERRGEBIET ZEICHNEN.<br>ROT · ANIMIERT · GEOREFERENZIERT.</div>

      <div class="tool-section-label" style="margin-top:4px">Category</div>
      <div class="cat-grid">
        <button class="cat-btn selected" id="cat-building" onclick="selectCat('building')"><span class="cat-icon">🏢</span> BUILDING</button>
        <button class="cat-btn" id="cat-vehicle" onclick="selectCat('vehicle')"><span class="cat-icon">🚗</span> VEHICLE</button>
        <button class="cat-btn" id="cat-road"     onclick="selectCat('road')"><span class="cat-icon">🛣</span> ROAD</button>
        <button class="cat-btn" id="cat-water"    onclick="selectCat('water')"><span class="cat-icon">💧</span> WATER</button>
        <button class="cat-btn" id="cat-area"     onclick="selectCat('area')"><span class="cat-icon">🌐</span> AREA</button>
        <button class="cat-btn" id="cat-poi"      onclick="selectCat('poi')"><span class="cat-icon">📍</span> POI</button>
      </div>
    </div>

    <div id="objList">
