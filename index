// ══════════════════════════════════════════════════════════════════
//  RECT DRAW (normal mode)
// ══════════════════════════════════════════════════════════════════
map.on('mousedown',e=>{
  if(mode!=='draw') return;
  if(e.originalEvent.button!==0) return;
  drawing=true; drawStart=e.latlng;
  drawTmpRect=L.rectangle([drawStart,drawStart],{color:'#fff',weight:1,fillColor:'#fff',fillOpacity:.05,dashArray:'4,4',interactive:false}).addTo(map);
});
map.on('mousemove',e=>{
  if(!drawing||!drawTmpRect) return;
  drawTmpRect.setBounds([drawStart,e.latlng]);
});
map.on('mouseup',e=>{
  if(!drawing) return; drawing=false;
  const b=L.latLngBounds(drawStart,e.latlng);
  const sw=b.getSouthWest(),ne=b.getNorthEast();
  if(drawTmpRect){map.removeLayer(drawTmpRect);drawTmpRect=null}
  if(Math.abs(ne.lat-sw.lat)<0.000015&&Math.abs(ne.lng-sw.lng)<0.000015) return;
  pendingData={type:'rect',bounds:{sw:[sw.lat,sw.lng],ne:[ne.lat,ne.lng]}};
  editingId=null; openModal('rect');
});

// ══════════════════════════════════════════════════════════════════
//  TAG PLACE
// ══════════════════════════════════════════════════════════════════
map.on('click',e=>{
  if(mode!=='tag') return;
  pendingData={type:'tag',latlng:[e.latlng.lat,e.latlng.lng]};
  editingId=null; openModal('tag');
});

// ══════════════════════════════════════════════════════════════════
//  FREEHAND CANVAS DRAWING
// ══════════════════════════════════════════════════════════════════
(function setupFreehand(){
  const canvas=document.getElementById('freeCanvas');
  let ctx=null;

  function resizeCanvas(){
    const mapEl=document.getElementById('map');
    canvas.width=mapEl.offsetWidth;
    canvas.height=mapEl.offsetHeight;
  }
  resizeCanvas();
  new ResizeObserver(resizeCanvas).observe(document.getElementById('map'));

  function getCtx(){
    if(!ctx) ctx=canvas.getContext('2d');
    return ctx;
  }

  canvas.addEventListener('mousedown',e=>{
    if(mode!=='free'&&mode!=='zone') return;
    freeDrawing=true;
    freePoints=[];
    const r=canvas.getBoundingClientRect();
    freePoints.push({x:e.clientX-r.left,y:e.clientY-r.top});
    const c=getCtx();
    c.clearRect(0,0,canvas.width,canvas.height);
    c.strokeStyle=mode==='zone'?'#ff2222':'#39ff14';
    c.lineWidth=mode==='zone'?2:1.5;
    c.setLineDash([4,3]);
    c.beginPath();
    c.moveTo(freePoints[0].x,freePoints[0].y);
  });

  canvas.addEventListener('mousemove',e=>{
    if(!freeDrawing) return;
    const r=canvas.getBoundingClientRect();
    const pt={x:e.clientX-r.left,y:e.clientY-r.top};
    freePoints.push(pt);
    const c=getCtx();
    c.lineTo(pt.x,pt.y);
    c.stroke();
  });

  canvas.addEventListener('mouseup',async e=>{
    if(!freeDrawing) return;
    freeDrawing=false;
    const c=getCtx();
    if(freePoints.length>0){c.lineTo(freePoints[0].x,freePoints[0].y);c.stroke()}

    if(freePoints.length<5){
      c.clearRect(0,0,canvas.width,canvas.height);
      return;
    }

    if(mode==='zone'){
      // Zone mode: keep raw polygon shape
      createZoneFromPoints(freePoints);
      c.clearRect(0,0,canvas.width,canvas.height);
    } else {
      // Free mode: OBB rectangle
      await analyzeFrehandArea(canvas, freePoints);
      c.clearRect(0,0,canvas.width,canvas.height);
    }
  });

  // Touch support
  canvas.addEventListener('touchstart',e=>{e.preventDefault();canvas.dispatchEvent(new MouseEvent('mousedown',{clientX:e.touches[0].clientX,clientY:e.touches[0].clientY}))},{passive:false});
  canvas.addEventListener('touchmove',e=>{e.preventDefault();canvas.dispatchEvent(new MouseEvent('mousemove',{clientX:e.touches[0].clientX,clientY:e.touches[0].clientY}))},{passive:false});
  canvas.addEventListener('touchend',e=>{e.preventDefault();canvas.dispatchEvent(new MouseEvent('mouseup'))},{passive:false});
})();

// ══════════════════════════════════════════════════════════════════
//  FREEHAND → ORIENTED BOUNDING BOX (OBB)
//  Nimmt die gezeichneten Bildschirm-Punkte, berechnet das minimale
//  umschließende Rechteck im optimalen Winkel und wandelt es in
//  georeferenzierte Koordinaten um.
// ══════════════════════════════════════════════════════════════════

// Convex Hull (Graham scan) auf Bildschirmpunkten
function convexHull(pts){
  const p=[...pts].sort((a,b)=>a.x-b.x||a.y-b.y);
  const cross=(o,a,b)=>(a.x-o.x)*(b.y-o.y)-(a.y-o.y)*(b.x-o.x);
  const lower=[]; for(const pt of p){while(lower.length>=2&&cross(lower[lower.length-2],lower[lower.length-1],pt)<=0)lower.pop();lower.push(pt)}
  const upper=[]; for(let i=p.length-1;i>=0;i--){const pt=p[i];while(upper.length>=2&&cross(upper[upper.length-2],upper[upper.length-1],pt)<=0)upper.pop();upper.push(pt)}
  upper.pop();lower.pop();
  return lower.concat(upper);
}

// Minimum Area Bounding Rectangle (Rotating Calipers)
function minAreaRect(pts){
  const hull=convexHull(pts);
  if(hull.length<2) return null;
  let best=null;
  for(let i=0;i<hull.length;i++){
    const a=hull[i], b=hull[(i+1)%hull.length];
    const dx=b.x-a.x, dy=b.y-a.y;
    const len=Math.hypot(dx,dy); if(len<1e-9) continue;
    const ux=dx/len, uy=dy/len;  // unit edge vector
    const vx=-uy, vy=ux;          // perpendicular
    let minP=Infinity,maxP=-Infinity,minQ=Infinity,maxQ=-Infinity;
    for(const p of hull){
      const proj=p.x*ux+p.y*uy;
      const perp=p.x*vx+p.y*vy;
      if(proj<minP)minP=proj; if(proj>maxP)maxP=proj;
      if(perp<minQ)minQ=perp; if(perp>maxQ)maxQ=perp;
    }
    const area=(maxP-minP)*(maxQ-minQ);
    if(!best||area<best.area){
      best={area,minP,maxP,minQ,maxQ,ux,uy,vx,vy};
    }
  }
  if(!best) return null;
  // 4 corners of the OBB in screen space
  const {minP,maxP,minQ,maxQ,ux,uy,vx,vy}=best;
  return [
    {x:minP*ux+minQ*vx, y:minP*uy+minQ*vy},
    {x:maxP*ux+minQ*vx, y:maxP*uy+minQ*vy},
    {x:maxP*ux+maxQ*vx, y:maxP*uy+maxQ*vy},
    {x:minP*ux+maxQ*vx, y:minP*uy+maxQ*vy},
  ];
}

async function analyzeFrehandArea(sourceCanvas, screenPoints){
  const corners=minAreaRect(screenPoints);
  if(!corners){toast('ZU WENIG PUNKTE');return}

  // Draw the final OBB preview on canvas briefly
  const ctx=sourceCanvas.getContext('2d');
  ctx.clearRect(0,0,sourceCanvas.width,sourceCanvas.height);
  ctx.strokeStyle='#ffffff';
  ctx.lineWidth=1.5;
  ctx.setLineDash([]);
  ctx.beginPath();
  corners.forEach((c,i)=>i===0?ctx.moveTo(c.x,c.y):ctx.lineTo(c.x,c.y));
  ctx.closePath();
  ctx.stroke();

  // Convert screen corners → lat/lng
  const geoCorners=corners.map(c=>map.containerPointToLatLng(L.point(c.x,c.y)));
  const polygon=geoCorners.map(ll=>[ll.lat,ll.lng]);

  // Compute center for rough size estimate
  const cx=corners.reduce((s,c)=>s+c.x,0)/4;
  const cy=corners.reduce((s,c)=>s+c.y,0)/4;

  // Edge lengths in pixels → to see aspect ratio
  const w=Math.hypot(corners[1].x-corners[0].x,corners[1].y-corners[0].y);
  const h=Math.hypot(corners[2].x-corners[1].x,corners[2].y-corners[1].y);

  // Flash the OBB for 400ms then clear and open modal
  setTimeout(()=>{
    ctx.clearRect(0,0,sourceCanvas.width,sourceCanvas.height);
    pendingData={type:'freehand', polygon};
    editingId=null;
    openModal('freehand');
  },400);
}


// ══════════════════════════════════════════════════════════════════
//  ZONE — Freihand Sperrgebiet
// ══════════════════════════════════════════════════════════════════
function createZoneFromPoints(screenPoints){
  // Simplify points (take every Nth for performance)
  const step=Math.max(1,Math.floor(screenPoints.length/60));
  const simplified=screenPoints.filter((_,i)=>i%step===0);
  const geoPolygon=simplified.map(p=>{
    const ll=map.containerPointToLatLng(L.point(p.x,p.y));
    return [ll.lat,ll.lng];
  });
  pendingData={type:'zone',polygon:geoPolygon};
  editingId=null;
  openModal('zone');
}


// ══════════════════════════════════════════════════════════════════
//  MODAL
// ══════════════════════════════════════════════════════════════════
function openModal(shapeType, editObj, prefillName='', prefillDesc=''){
  const c=catMeta[editObj?editObj.cat:activeCat];
  const icons={rect:'▭',tag:'◉',freehand:'✦',zone:'⛔'};
  document.getElementById('modIcon').textContent=icons[shapeType]||'▭';
  document.getElementById('modTitle').textContent=editObj?'EDIT OBJECT':'DEFINE OBJECT';
  document.getElementById('modCat').textContent=c.icon+' '+c.label;
  document.getElementById('inName').value=editObj?editObj.name:(prefillName||'');
  document.getElementById('inDesc').value=editObj?editObj.desc:(prefillDesc||'');
  document.getElementById('inRotate').value=editObj?editObj.rotation||0:0;
  document.getElementById('rotVal').textContent=(editObj?editObj.rotation||0:0)+'°';
  document.getElementById('rotateField').style.display=shapeType==='rect'?'block':'none';
  // hide anim picker for tags (tags have their own style)
  document.getElementById('animField').style.display=shapeType==='tag'?'none':'block';

  // Build color + anim pickers
  const curColor = editObj?editObj.color||'#ffffff':'#ffffff';
  const curAnim  = editObj?editObj.anim||'anim-march':'anim-march';
  buildColorRow(curColor);
  buildAnimGrid(curAnim);

  document.getElementById('modalBg').classList.add('open');
  setTimeout(()=>document.getElementById('inName').focus(),80);
}

function cancelModal(){
  document.getElementById('modalBg').classList.remove('open');
  clearPreview(); pendingData=null; editingId=null;
}

let previewRotLayer=null;
function updatePreviewRotation(){
  if(editingId===null) return;
  const obj=objects.find(o=>o.id===editingId);
  if(!obj||obj.type!=='rect') return;
  const rotation=parseInt(document.getElementById('inRotate').value)||0;
  if(layers[obj.id]) layers[obj.id].setStyle({opacity:.25,fillOpacity:.04});
  const corners=getRotatedCorners(obj.bounds.sw,obj.bounds.ne,rotation);
  if(previewLayer){previewLayer.setLatLngs(corners)}
  else{previewLayer=L.polygon(corners,{color:'#fff',weight:2,fillColor:'#fff',fillOpacity:.15,dashArray:'3,4',interactive:false}).addTo(map)}
}

function clearPreview(){
  if(previewLayer){map.removeLayer(previewLayer);previewLayer=null}
  if(editingId!==null){
    const obj=objects.find(o=>o.id===editingId);
    if(obj&&layers[obj.id]) layers[obj.id].setStyle({opacity:1,fillOpacity:.1});
  }
}

function confirmModal(){
  const name=document.getElementById('inName').value.trim()||'UNNAMED';
  const desc=document.getElementById('inDesc').value.trim();
  const rotation=parseInt(document.getElementById('inRotate').value)||0;
  const color=selectedColor||'#ffffff';
  const anim=selectedAnim||'anim-march';
  document.getElementById('modalBg').classList.remove('open');
  clearPreview();

  if(editingId!==null){
    const obj=objects.find(o=>o.id===editingId);
    if(obj){
      obj.name=name; obj.desc=desc; obj.rotation=rotation; obj.color=color; obj.anim=anim;
      if(obj.type==='zone'){
        // Zone: remove old SVG overlay + border
        if(layers[obj.id]&&layers[obj.id]._isZone){
          map.removeLayer(layers[obj.id].border);
          map.off('moveend zoomend move zoom',layers[obj.id].updateZoneSVG);
          const sv=layers[obj.id].svgOverlay;
          if(sv&&sv.parentNode) sv.parentNode.removeChild(sv);
          delete layers[obj.id];
        }
      } else if(layers[obj.id]){
        map.removeLayer(layers[obj.id]); delete layers[obj.id];
      }
      renderObject(obj); renderSidebar(); toast('UPDATED: '+name);
    }
    editingId=null; pendingData=null; return;
  }

  const id=Date.now()+Math.random();
  const obj={id,name,desc,rotation,color,anim,cat:activeCat,...pendingData};
  objects.push(obj); renderObject(obj); renderSidebar(); pendingData=null;
  toast('COMMITTED: '+name);
}

// ══════════════════════════════════════════════════════════════════
//  ZONE HATCH SVG OVERLAY
//  Erzeugt ein SVG mit animiertem diagonalem Strichmuster
//  das sich nach unten-rechts bewegt (Sperrgebiet-Stil)
// ══════════════════════════════════════════════════════════════════
function createZoneHatchOverlay(obj, patId, clipId, zoneColor){
  const ns='http://www.w3.org/2000/svg';
  const svg=document.createElementNS(ns,'svg');
  svg.setAttribute('xmlns',ns);
  svg.style.cssText='position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:400;overflow:visible';

  // Animated hatch pattern — diagonal lines moving diagonally down-right
  const defs=document.createElementNS(ns,'defs');

  // ClipPath to confine hatch to polygon shape
  const clipPath=document.createElementNS(ns,'clipPath');
  clipPath.setAttribute('id',clipId);
  const clipPoly=document.createElementNS(ns,'polygon');
  clipPoly.setAttribute('class','zone-clip-poly');
  clipPath.appendChild(clipPoly);
  defs.appendChild(clipPath);

  // Pattern: diagonal lines at ~45°, spacing 14px, animated offset
  const pattern=document.createElementNS(ns,'pattern');
  pattern.setAttribute('id',patId);
  pattern.setAttribute('patternUnits','userSpaceOnUse');
  pattern.setAttribute('width','14');
  pattern.setAttribute('height','14');
  pattern.setAttribute('patternTransform','rotate(-45)');

  // Animate the pattern position — moves diagonally, creating flowing effect
  const anim=document.createElementNS(ns,'animateTransform');
  anim.setAttribute('attributeName','patternTransform');
  anim.setAttribute('type','translate');
  anim.setAttribute('from','0 0');
  anim.setAttribute('to','14 14');
  anim.setAttribute('dur','0.8s');
  anim.setAttribute('repeatCount','indefinite');
  anim.setAttribute('additive','sum');
  pattern.appendChild(anim);

  // The actual line inside the pattern tile
  const line=document.createElementNS(ns,'line');
  line.setAttribute('x1','0'); line.setAttribute('y1','0');
  line.setAttribute('x2','0'); line.setAttribute('y2','14');
  line.setAttribute('stroke', zoneColor||'#ff2222');
  line.setAttribute('stroke-width','1.5');
  line.setAttribute('stroke-opacity','0.55');
  pattern.appendChild(line);
  defs.appendChild(pattern);
  svg.appendChild(defs);

  // Filled polygon using the hatch pattern, clipped to shape
  const fillRect=document.createElementNS(ns,'polygon');
  fillRect.setAttribute('class','zone-fill-poly');
  fillRect.setAttribute('fill','url(#'+patId+')');
  fillRect.setAttribute('clip-path','url(#'+clipId+')');
  fillRect.setAttribute('stroke','none');
  svg.appendChild(fillRect);

  return svg;
}


// ══════════════════════════════════════════════════════════════════
//  RENDER
// ══════════════════════════════════════════════════════════════════
function getRotatedCorners(swArr,neArr,angleDeg){
  const sw=L.latLng(swArr[0],swArr[1]), ne=L.latLng(neArr[0],neArr[1]);
  const cx=(sw.lat+ne.lat)/2, cy=(sw.lng+ne.lng)/2;
  const corners=[[sw.lat,sw.lng],[sw.lat,ne.lng],[ne.lat,ne.lng],[ne.lat,sw.lng]];
  const a=angleDeg*Math.PI/180, cos=Math.cos(a), sin=Math.sin(a);
  const lngScale=Math.cos(cx*Math.PI/180);
  return corners.map(([lat,lng])=>{
    const dlat=lat-cx, dlng=(lng-cy)*lngScale;
    return [cx+dlat*cos-dlng*sin, cy+(dlat*sin+dlng*cos)/lngScale];
  });
}

function renderObject(obj){
  if(obj.type==='rect'){
    const col=obj.color||'#ffffff';
    const animCls=obj.anim||'anim-march';
    const corners=getRotatedCorners(obj.bounds.sw,obj.bounds.ne,obj.rotation||0);
    const layer=L.polygon(corners,{
      color:col,weight:1.5,fillColor:col,fillOpacity:.1,
      className:animCls
    }).addTo(map);
    layer.on('click',()=>selectObj(obj.id));
    layer.on('contextmenu',e=>showCtxMenu(e.originalEvent,obj.id));
    layers[obj.id]=layer;

  } else if(obj.type==='freehand'){
    const col=obj.color||'#39ff14';
    const animCls=obj.anim||'anim-march';
    const layer=L.polygon(obj.polygon,{
      color:col,weight:1.5,fillColor:col,fillOpacity:.08,
      className:animCls
    }).addTo(map);
    layer.on('click',()=>selectObj(obj.id));
    layer.on('contextmenu',e=>showCtxMenu(e.originalEvent,obj.id));
    layers[obj.id]=layer;

  } else if(obj.type==='zone'){
    // SVG pattern fill: animated diagonal hatching inside clip-path of polygon
    const patId='hatch-'+Math.floor(obj.id);
    const clipId='clip-'+Math.floor(obj.id);

    // Leaflet polygon for the border (no fill — we draw fill via SVG overlay)
    const border=L.polygon(obj.polygon,{
      color:'#ff2222',weight:2,fillOpacity:0,
      dashArray:'6 4',className:'anim-zone',interactive:true
    }).addTo(map);

    border.on('click',()=>selectObj(obj.id));
    border.on('contextmenu',e=>showCtxMenu(e.originalEvent,obj.id));

    // Create an SVG overlay for animated hatching
    const svgOverlay=createZoneHatchOverlay(obj, patId, clipId, zoneCol);
    map.getPanes().overlayPane.appendChild(svgOverlay);

    // Update SVG position on map move/zoom
    function updateZoneSVG(){
      const sz=map.getSize();
      svgOverlay.setAttribute('width', sz.x);
      svgOverlay.setAttribute('height', sz.y);
      // Reproject polygon points to screen
      const pts=obj.polygon.map(([lat,lng])=>{
        const p=map.latLngToLayerPoint(L.latLng(lat,lng));
        return p.x+','+p.y;
      }).join(' ');
      const polyEl=svgOverlay.querySelector('.zone-fill-poly');
      const clipEl=svgOverlay.querySelector('.zone-clip-poly');
      if(polyEl) polyEl.setAttribute('points', pts);
      if(clipEl) clipEl.setAttribute('points', pts);
    }
    map.on('moveend zoomend move zoom', updateZoneSVG);
    updateZoneSVG();

    // Store both for cleanup
    layers[obj.id]={border, svgOverlay, updateZoneSVG, getBounds:()=>border.getBounds(), _isZone:true};

  } else if(obj.type==='tag'){
    const icon=buildTagIcon(obj);
    const marker=L.marker(obj.latlng,{icon,zIndexOffset:500}).addTo(map);
    marker.on('click',()=>selectObj(obj.id));
    marker.on('contextmenu',e=>showCtxMenu(e.originalEvent,obj.id));
    layers[obj.id]=marker;
  }
}

function buildTagIcon(obj){
  const c=catMeta[obj.cat];
  const col=obj.color||'';
  const colStyle=col?`style="color:${col}"`:''
  return L.divIcon({
    html:`<div class="tag-marker tag-${obj.cat}" ${colStyle}>
      <div class="tag-dot" ${col?`style="background:${col};border-color:${col}"`:''} ></div>
      <div class="tag-ring" ${col?`style="border-color:${col}"`:''} ></div>
      <div class="tag-ring2" ${col?`style="border-color:${col}"`:''} ></div>
      <div class="tag-label" ${col?`style="border-color:${col}40;color:${col}"`:''} >${obj.name}</div></div>`,
    className:'',iconSize:[20,20],iconAnchor:[10,10]
  });
}

function selectObj(id){
  selId=id; renderSidebar();
  const obj=objects.find(o=>o.id===id);
  if(!obj) return;
  const layer=layers[id];
  if(!layer) return;
  if(obj.type==='tag'){
    map.setView(obj.latlng,Math.max(map.getZoom(),17));
  } else {
    const bounds=layer._isZone?layer.getBounds():layer.getBounds();
    map.fitBounds(bounds,{padding:[60,60],maxZoom:20});
  }
}

