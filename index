//  AIS LIVE SHIP TRACKING — aisstream.io WebSocket
//  Strait of Hormuz bounding box, 30-min position freeze
// ══════════════════════════════════════════════════════════════════

// Strait of Hormuz + Gulf of Oman bounding box
const HORMUZ_BBOX = [[22.0, 52.0], [27.5, 60.5]];

let aisWs = null;
let aisActive = false;
let aisApiKey = localStorage.getItem('ais_api_key') || '9e97278caa7a4efdc14ab847bfaac809fd216feb';
let shipMarkers = {};       // mmsi → {marker, data, lastUpdated}
let shipFreezeTimer = null;
const AIS_FREEZE_MS = 30 * 60 * 1000; // 30 minutes

// Ship type codes → label
function shipTypeLabel(t){
  if(!t) return 'UNKNOWN';
  if(t>=70&&t<=79) return 'CARGO';
  if(t>=80&&t<=89) return 'TANKER';
  if(t>=60&&t<=69) return 'PASSENGER';
  if(t>=30&&t<=39) return 'FISHING';
  if(t>=50&&t<=59) return 'SPECIAL';
  if(t>=20&&t<=29) return 'WIG';
  if(t===35||t===36) return 'MILITARY';
  if(t>=40&&t<=49) return 'HIGH SPEED';
  return 'VESSEL';
}

function shipTypeColor(t){
  if(!t) return '#888';
  if(t>=80&&t<=89) return '#ff8800'; // tanker = orange
  if(t>=70&&t<=79) return '#00aaff'; // cargo = blue
  if(t>=60&&t<=69) return '#ffffff'; // passenger = white
  if(t>=30&&t<=39) return '#39ff14'; // fishing = green
  if(t===35||t===36) return '#ff2222'; // military = red
  return '#bbbbbb';
}

function navStatusLabel(s){
  const labels={
    0:'UNDERWAY ENGINE',1:'AT ANCHOR',2:'NOT UNDER COMMAND',3:'RESTRICTED MANEUVERABILITY',
    4:'CONSTRAINED BY DRAUGHT',5:'MOORED',6:'AGROUND',7:'ENGAGED IN FISHING',8:'UNDERWAY SAILING',
    15:'UNDEFINED'
  };
  return labels[s]||'STATUS '+s;
}

function toggleAIS(){
  if(aisActive){ stopAIS(); return; }
  if(!aisApiKey){
    document.getElementById('aisKeyPanel').style.display='flex';
    return;
  }
  connectAIS(aisApiKey);
}

function closeAisKeyPanel(){
  document.getElementById('aisKeyPanel').style.display='none';
}

function startAISWithKey(){
  const key = document.getElementById('aisKeyInput').value.trim();
  if(!key){ toast('API KEY REQUIRED'); return; }
  aisApiKey = key;
  localStorage.setItem('ais_api_key', key);
  closeAisKeyPanel();
  connectAIS(key);
}

function connectAIS(apiKey){
  if(aisWs){ try{aisWs.close();}catch(e){} aisWs=null; }

  aisActive = true;
  const btn = document.getElementById('aisToggleBtn');
  btn.textContent = '⚓ AIS LIVE ●';
  btn.style.color = '#39ff14';
  btn.style.borderColor = '#39ff14';

  document.getElementById('aisCount').textContent = 'AIS: CONNECTING...';
  toast('AIS // VERBINDE MIT HORMUZ FEED');

  try {
    aisWs = new WebSocket('wss://stream.aisstream.io/v0/stream');
  } catch(e) {
    document.getElementById('aisCount').textContent = 'AIS: WS ERROR';
    toast('AIS // WEBSOCKET NICHT VERFÜGBAR');
    return;
  }

  aisWs.onopen = () => {
    // Correct format: BoundingBoxes = array of boxes, each box = [[minLat,minLng],[maxLat,maxLng]]
    const sub = {
      APIKey: apiKey,
      Apikey: apiKey,
      BoundingBoxes: [[[22.0, 52.0], [27.5, 60.5]]],
      FilterMessageTypes: ['PositionReport', 'ShipStaticData']
    };
    aisWs.send(JSON.stringify(sub));
    console.log('AIS sub sent:', JSON.stringify(sub));
    document.getElementById('aisCount').textContent = 'AIS: LIVE';
    toast('AIS // HORMUZ FEED AKTIV');
  };

  let _msgCount = 0;
  aisWs.onmessage = (evt) => {
    try{
      const msg = JSON.parse(evt.data);
      _msgCount++;
      if(_msgCount<=3) console.log('AIS msg #'+_msgCount, JSON.stringify(msg).slice(0,300));
      if(msg.error){
        document.getElementById('aisCount').textContent = 'AIS ERR: '+msg.error;
        toast('AIS: '+msg.error);
        return;
      }
      handleAISMessage(msg);
    }catch(e){ console.warn('AIS parse error', e, evt.data?.slice(0,100)); }
  };

  aisWs.onerror = (e) => {
    console.error('AIS WS error', e);
    document.getElementById('aisCount').textContent = 'AIS: CONNECTION ERROR';
    toast('AIS // CONNECTION ERROR');
  };

  aisWs.onclose = (ev) => {
    console.log('AIS WS closed', ev.code, ev.reason);
    if(!aisActive) return;
    document.getElementById('aisCount').textContent = 'AIS: RECONNECTING (' + ev.code + ')...';
    // Reconnect after 4s — aisstream closes every ~2min normally
    setTimeout(()=>{ if(aisActive) connectAIS(aisApiKey); }, 4000);
  };
}

function stopAIS(){
  aisActive = false;
  if(aisWs){ aisWs.close(); aisWs=null; }
  const btn = document.getElementById('aisToggleBtn');
  btn.textContent = '⚓ AIS LIVE';
  btn.style.color = '#2a6a2a';
  btn.style.borderColor = '#1a3a1a';
  document.getElementById('aisCount').textContent = 'AIS: —';
  toast('AIS // FEED GESTOPPT');
}

function handleAISMessage(msg){
  const type = msg.MessageType;
  if(!type) return;
  const meta = msg.MetaData || {};

  // MetaData fields from official JS example
  const mmsi = String(meta.MMSI || meta.MMSI_String || meta.UserID || '').trim();
  if(!mmsi || mmsi==='0') return;

  // Position: try MetaData first (lat/lng lowercase), then Message body
  const pr0 = (msg.Message||{}).PositionReport || {};
  const lat  = parseFloat(meta.latitude  ?? meta.Latitude  ?? pr0.Latitude  ?? 0);
  const lng  = parseFloat(meta.longitude ?? meta.Longitude ?? pr0.Longitude ?? 0);
  if(!lat || !lng) return;
  // Sanity — Hormuz + surrounding area
  if(lat<18||lat>30||lng<50||lng>62) return;

  const now = Date.now();

  // 30-min freeze: ignore if updated recently
  if(shipMarkers[mmsi] && shipMarkers[mmsi].lastUpdated){
    if(now - shipMarkers[mmsi].lastUpdated < AIS_FREEZE_MS) {
      // Only update static data if available
      if(type==='ShipStaticData' && msg.Message && msg.Message.ShipStaticData){
        const sd = msg.Message.ShipStaticData;
        shipMarkers[mmsi].data = {...(shipMarkers[mmsi].data||{}), ...sd};
      }
      return;
    }
  }

  // Extract data
  let shipData = shipMarkers[mmsi]?.data || {};

  const msgBody = msg.Message || {};

  if(type==='PositionReport'){
    // Official docs: fields are PascalCase — Latitude, Longitude, UserID, Sog, Cog etc.
    const pr = msgBody.PositionReport || {};
    const prLat = pr.Latitude  ?? pr.latitude  ?? lat;
    const prLng = pr.Longitude ?? pr.longitude ?? lng;
    shipData = {...shipData,
      mmsi,
      lat: prLat, lng: prLng,
      sog: pr.Sog,
      cog: pr.Cog,
      heading: pr.TrueHeading,
      navStatus: pr.NavigationalStatus,
      name: (meta.ShipName||'').trim() || shipData.name || 'MMSI '+mmsi,
    };
  } else if(type==='ShipStaticData'){
    const sd = msgBody.ShipStaticData || {};
    const rawName = (sd.Name||sd.ShipName||meta.ShipName||'').replace(/[^\x20-\x7E]/g,'').trim();
    shipData = {...shipData,
      mmsi, lat, lng,
      name: rawName || shipData.name || 'MMSI '+mmsi,
      shipType: sd.Type,
      callSign: (sd.CallSign||'').trim(),
      destination: (sd.Destination||'').trim(),
      draught: sd.MaximumStaticDraught,
      dimA: sd.DimensionToBow, dimB: sd.DimensionToStern,
      dimC: sd.DimensionToPort, dimD: sd.DimensionToStarboard,
    };
  } else { return; }

  shipData.lat = lat; shipData.lng = lng;
  shipData.lastSeen = new Date().toISOString();

  // Update or create marker
  if(shipMarkers[mmsi]?.marker){
    shipMarkers[mmsi].marker.setLatLng([lat,lng]);
    shipMarkers[mmsi].data = shipData;
    shipMarkers[mmsi].lastUpdated = now;
    shipMarkers[mmsi].marker.setIcon(buildShipIcon(shipData));
  } else {
    const icon = buildShipIcon(shipData);
    const marker = L.marker([lat,lng],{icon,zIndexOffset:1000}).addTo(map);
    marker.on('click', ()=>showShipPanel(mmsi));
    shipMarkers[mmsi] = {marker, data:shipData, lastUpdated:now};
  }

  // Update counter
  document.getElementById('aisCount').textContent = `AIS: ${Object.keys(shipMarkers).length} VESSELS`;
}

function buildShipIcon(d){
  const col = shipTypeColor(d.shipType);
  const hdg = (d.cog||0) - 90; // rotate arrow
  return L.divIcon({
    html:`<div class="ship-marker" style="color:${col};transform:rotate(${hdg}deg)" title="${d.name||d.mmsi}">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
        <polygon points="8,1 14,14 8,11 2,14" fill="${col}" fill-opacity="0.85" stroke="${col}" stroke-width="0.5"/>
      </svg>
      <div class="ship-pulse" style="border-color:${col}"></div>
    </div>`,
    className:'',iconSize:[16,16],iconAnchor:[8,8]
  });
}

function showShipPanel(mmsi){
  const s = shipMarkers[mmsi];
  if(!s) return;
  const d = s.data;
  const col = shipTypeColor(d.shipType);
  const typeStr = shipTypeLabel(d.shipType);
  const length = (d.dimA&&d.dimB)?Math.round(d.dimA+d.dimB)+' m':'—';
  const beam   = (d.dimC&&d.dimD)?Math.round(d.dimC+d.dimD)+' m':'—';
  const ago    = s.lastUpdated ? Math.round((Date.now()-s.lastUpdated)/60000)+'min ago' : '—';

  document.getElementById('shipPanelBody').innerHTML = `
    <div style="margin-bottom:10px">
      <div style="font-size:14px;font-weight:700;color:${col};letter-spacing:1px;margin-bottom:2px">${d.name||'UNKNOWN'}</div>
      <div style="font-size:9px;color:#555;letter-spacing:1px">${typeStr} · MMSI ${d.mmsi}</div>
    </div>
    <table style="width:100%;border-collapse:collapse;font-size:9px;letter-spacing:.5px">
      ${row('CALL SIGN', d.callSign||'—')}
      ${row('STATUS', d.navStatus!==undefined?navStatusLabel(d.navStatus):'—')}
      ${row('SPEED', d.sog!==undefined?(d.sog+' kn'):'—')}
      ${row('COURSE', d.cog!==undefined?(d.cog+'°'):'—')}
      ${row('HEADING', d.heading&&d.heading!==511?(d.heading+'°'):'—')}
      ${row('DESTINATION', d.destination||'—')}
      ${row('DRAUGHT', d.draught?(d.draught+' m'):'—')}
      ${row('LENGTH', length)}
      ${row('BEAM', beam)}
      ${row('POSITION', d.lat.toFixed(4)+', '+d.lng.toFixed(4))}
      ${row('LAST UPDATE', ago)}
    </table>
    <div style="margin-top:10px;display:flex;gap:6px">
      <a href="https://www.marinetraffic.com/en/ais/details/ships/mmsi:${d.mmsi}" target="_blank"
        style="font-size:9px;letter-spacing:1px;color:#888;text-decoration:none;border:1px solid #333;padding:4px 8px;transition:all .1s"
        onmouseover="this.style.color='#fff';this.style.borderColor='#888'"
        onmouseout="this.style.color='#888';this.style.borderColor='#333'">
        ↗ MARINETRAFFIC
      </a>
    </div>
  `;
  document.getElementById('shipPanel').style.display = 'block';
}

function row(label, val){
  return `<tr>
    <td style="color:#555;padding:3px 0;border-bottom:1px solid #111;width:44%">${label}</td>
    <td style="color:#ccc;padding:3px 0;border-bottom:1px solid #111">${val}</td>
  </tr>`;
}

// Add ship marker CSS
const shipCSS = document.createElement('style');
shipCSS.textContent = `
.ship-marker{position:relative;width:16px;height:16px;display:flex;align-items:center;justify-content:center;cursor:pointer}
.ship-pulse{position:absolute;width:16px;height:16px;border-radius:50%;border:1px solid;animation:ring-pulse 3s infinite;pointer-events:none}
#aisKeyPanel{display:none}
#aisKeyPanel.open{display:flex!important}
`;
document.head.appendChild(shipCSS);

</script>

