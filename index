function renderSidebar(){
  const n=objects.length;
  document.getElementById('sbCount').textContent=n;
  document.getElementById('objCountTop').textContent=n;
  const list=document.getElementById('objList');
  if(n===0){
    list.innerHTML='<div class="empty-state">NO OBJECTS<br>─────────────────<br>DRAW POLYGON OR<br>PLACE TAG<br>OR USE ✦ AI MODE</div>';
    return;
  }
  list.innerHTML=objects.map(o=>{
    const c=catMeta[o.cat];
    const rotInfo=o.type==='rect'&&o.rotation?' · '+o.rotation+'°':'';
    const aiInfo=o.type==='freehand'?' · OBB':o.type==='zone'?' · ZONE':'' ;
    return `<div class="obj-card${selId===o.id?' sel':''}" onclick="selectObj(${o.id})">
      <div class="obj-icon">${c.icon}</div>
      <div class="obj-info">
        <div class="obj-name">${o.name}</div>
        <div class="obj-meta">${c.label} · ${o.type==='rect'?'POLYGON':o.type==='freehand'?'OBB-POLY':o.type==='zone'?'SPERRGEBIET':'TAG'}${rotInfo}${aiInfo}</div>
      </div>
      <div class="obj-actions">
        <button class="obj-action-btn edit" onclick="editObj(event,${o.id})" title="Edit">✎</button>
        <button class="obj-action-btn" onclick="deleteObjE(event,${o.id})" title="Delete">✕</button>
      </div>
    </div>`;
  }).join('');
}

function editObj(e,id){
  e.stopPropagation();
  const obj=objects.find(o=>o.id===id); if(!obj) return;
  editingId=id; pendingData={type:obj.type}; openModal(obj.type,obj);
}
function deleteObjE(e,id){e.stopPropagation();deleteObj(id)}
function deleteObj(id){
  const l=layers[id];
  if(l){
    if(l._isZone){
      // Zone: remove border layer + SVG overlay + event listener
      map.removeLayer(l.border);
      map.off('moveend zoomend move zoom', l.updateZoneSVG);
      if(l.svgOverlay && l.svgOverlay.parentNode) l.svgOverlay.parentNode.removeChild(l.svgOverlay);
    } else {
      map.removeLayer(l);
    }
  }
  delete layers[id];
  objects=objects.filter(o=>o.id!==id);
  if(selId===id) selId=null;
  renderSidebar(); toast('OBJECT DELETED');
}
function clearAll(){
  if(!confirm('DELETE ALL OBJECTS?')) return;
  objects.forEach(o=>{
    const l=layers[o.id];
    if(l){
      if(l._isZone){
        map.removeLayer(l.border);
        map.off('moveend zoomend move zoom', l.updateZoneSVG);
        if(l.svgOverlay&&l.svgOverlay.parentNode) l.svgOverlay.parentNode.removeChild(l.svgOverlay);
      } else { map.removeLayer(l); }
    }
    delete layers[o.id];
  });
  objects=[];selId=null;renderSidebar();toast('ALL CLEARED');
}

