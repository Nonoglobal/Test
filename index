  else if(m==='free') document.getElementById('stHelp').textContent='FREIHAND ZEICHNEN — OBB RECHTECK';
  else if(m==='zone') document.getElementById('stHelp').textContent='SPERRGEBIET FREIHAND EINZEICHNEN — LOSLASSEN = FERTIG';
